    "/file/file/upload": {
      "post": {
        "summary": "上传文件",
        "description": "文件上传接口，支持上传图片、文档等文件，无需鉴权",
        "tags": ["文件服务"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UploadFileReqVO"
              },
              "examples": {
                "上传图片": {
                  "value": {
                    "file": "<file>"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResponseObject"
                },
                "examples": {
                  "成功": {
                    "value": {
                      "success": true,
                      "message": "文件上传成功",
                      "errorCode": null,
                      "data": {
                        "url": "https://oss.example.com/2026/06/25/test.jpg",
                        "fileName": "test.jpg",
                        "fileSize": 102400
                      }
                    }
                  },
                  "失败": {
                    "value": {
                      "success": false,
                      "message": "文件不能为空",
                      "errorCode": "OSS-10001",
                      "data": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
