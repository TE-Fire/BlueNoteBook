{
  "openapi": "3.0.0",
  "info": {
    "title": "BlueNote 微服务 API",
    "description": "BlueNote 小蓝书微服务架构项目的 RESTful API 接口文档，统一通过网关层访问",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "网关入口（本地开发环境），端口配置来自 bluenote-gateway application.yml"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "用户登录/注册",
        "description": "用户登录或注册接口，支持手机号验证码登录和账号密码登录两种方式",
        "tags": ["用户认证"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserLoginReqVO"
              },
              "examples": {
                "验证码登录": {
                  "value": {
                    "phone": "13800138000",
                    "code": "123456",
                    "password": null,
                    "type": 1
                  }
                },
                "密码登录": {
                  "value": {
                    "phone": "13800138000",
                    "code": null,
                    "password": "123456",
                    "type": 2
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResponseString"
                },
                "examples": {
                  "成功": {
                    "value": {
                      "success": true,
                      "message": null,
                      "errorCode": null,
                      "data": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    }
                  },
                  "失败": {
                    "value": {
                      "success": false,
                      "message": "验证码错误",
                      "errorCode": "AUTH-20001",
                      "data": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "用户登出",
        "description": "用户登出接口，无需鉴权",
        "tags": ["用户认证"],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResponseObject"
                },
                "examples": {
                  "成功": {
                    "value": {
                      "success": true,
                      "message": "登出成功",
                      "errorCode": null,
                      "data": null
                    }
                  },
                  "失败": {
                    "value": {
                      "success": false,
                      "message": "用户未登录",
                      "errorCode": "AUTH-30001",
                      "data": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/password/update": {
      "post": {
        "summary": "修改密码（认证模块）",
        "description": "用户修改密码接口",
        "tags": ["用户认证"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthUpdatePasswordReqVO"
              },
              "examples": {
                "修改密码": {
                  "value": {
                    "newPassword": "123456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResponseObject"
                },
                "examples": {
                  "成功": {
                    "value": {
                      "success": true,
                      "message": "密码修改成功",
                      "errorCode": null,
                      "data": null
                    }
                  },
                  "失败": {
                    "value": {
                      "success": false,
                      "message": "新密码不能为空",
                      "errorCode": "AUTH-10001",
                      "data": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/verification/code/send": {
      "post": {
        "summary": "发送短信验证码",
        "description": "发送短信验证码到指定手机号",
        "tags": ["验证码服务"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendVerificationCodeReqVO"
              },
              "examples": {
                "发送验证码": {
                  "value": {
                    "phone": "13800138000"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResponseObject"
                },
                "examples": {
                  "成功": {
                    "value": {
                      "success": true,
                      "message": "短信发送成功",
                      "errorCode": null,
                      "data": null
                    }
                  },
                  "失败": {
                    "value": {
                      "success": false,
                      "message": "发送短信太频繁，请稍后再试",
                      "errorCode": "AUTH-20002",
                      "data": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/user/user/update": {
