  "components": {
    "schemas": {
      "UserLoginReqVO": {
        "type": "object",
        "description": "登录请求入参",
        "properties": {
          "phone": {
            "type": "string",
            "description": "手机号",
            "example": "13800138000"
          },
          "code": {
            "type": "string",
            "description": "验证码（验证码登录时必填）",
            "example": "123456"
          },
          "password": {
            "type": "string",
            "description": "密码（密码登录时必填）",
            "example": "123456"
          },
          "type": {
            "type": "integer",
            "description": "登录类型：1-手机号验证码登录，2-账号密码登录",
            "example": 1
          }
        },
        "required": ["phone", "type"]
      },
      "AuthUpdatePasswordReqVO": {
        "type": "object",
        "description": "认证模块修改密码请求入参",
        "properties": {
          "newPassword": {
            "type": "string",
            "description": "新密码",
            "example": "123456"
          }
        },
        "required": ["newPassword"]
      },
      "SendVerificationCodeReqVO": {
        "type": "object",
        "description": "获取验证码接口请求体",
        "properties": {
          "phone": {
            "type": "string",
            "description": "手机号",
            "example": "13800138000"
          }
        },
        "required": ["phone"]
      },
      "UpdateUserInfoReqVO": {
        "type": "object",
        "description": "用户信息修改请求入参",
        "properties": {
          "nickname": {
            "type": "string",
            "description": "昵称"
          },
          "avatar": {
            "type": "string",
            "format": "binary",
            "description": "头像文件"
          },
          "xiaohashuId": {
            "type": "string",
            "description": "小蓝书号"
          },
          "sex": {
            "type": "integer",
            "description": "性别"
          },
          "birthday": {
            "type": "string",
            "format": "date",
            "description": "生日"
          },
          "introduction": {
            "type": "string",
            "description": "个人简介"
          },
          "backgroundImg": {
            "type": "string",
            "format": "binary",
            "description": "背景图"
          }
        }
      },
      "UserUpdatePasswordReqVO": {
        "type": "object",
        "description": "用户模块密码更新请求入参",
        "properties": {
          "encodePassword": {
            "type": "string",
            "description": "加密后的密码"
          }
        },
        "required": ["encodePassword"]
      },
      "FindUserByIdReqDTO": {
        "type": "object",
        "description": "根据ID查询用户请求入参",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "用户ID",
            "example": 1
          }
        },
        "required": ["id"]
      },
      "FindUsersByIdsReqDTO": {
        "type": "object",
        "description": "批量查询用户请求入参",
        "properties": {
          "ids": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "description": "用户ID列表"
          }
        },
        "required": ["ids"]
      },
      "FindUserByPhoneReqDTO": {
        "type": "object",
        "description": "根据手机号查询用户请求入参",
        "properties": {
          "phone": {
            "type": "string",
            "description": "手机号",
            "example": "13800138000"
          }
        },
        "required": ["phone"]
      },
      "RegisterUserReqDTO": {
        "type": "object",
        "description": "用户注册请求入参",
        "properties": {
          "phone": {
            "type": "string",
            "description": "手机号",
            "example": "13800138000"
          }
        },
        "required": ["phone"]
      },
      "UploadFileReqVO": {
        "type": "object",
        "description": "文件上传请求入参",
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "上传的文件"
          }
        },
        "required": ["file"]
      },
      "PublishNoteReqVO": {
        "type": "object",
        "description": "笔记发布请求入参",
        "properties": {
          "content": {
            "type": "string",
            "description": "笔记内容"
          },
          "title": {
            "type": "string",
            "description": "笔记标题"
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "图片URL列表"
          },
          "topicIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "description": "话题ID列表"
          }
        },
        "required": ["content"]
      },
      "FindNoteDetailReqVO": {
        "type": "object",
        "description": "查询笔记详情请求入参",
        "properties": {
          "noteId": {
            "type": "integer",
            "format": "int64",
            "description": "笔记ID",
            "example": 1
          }
        },
        "required": ["noteId"]
      },
      "UpdateNoteReqVO": {
        "type": "object",
        "description": "修改笔记请求入参",
        "properties": {
